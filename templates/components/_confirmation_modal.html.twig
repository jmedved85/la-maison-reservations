{# Confirmation Modal #}
{% if reservationData is defined and reservationData is not null %}
    {% set reservation = reservationData %}

    <div class="modal fade" id="confirmationModal" tabindex="-1" aria-labelledby="confirmationModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h3 class="modal-title w-100 text-center" style="color: var(--text-dark);" id="confirmationModalLabel">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        {{ 'reservation_confirmed'|trans }}!
                    </h3>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    {# Success Message #}
                    <div class="text-center mb-4">
                        <div class="success-icon mb-3">
                            <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                        </div>
                        <p class="lead text-muted">{{ 'reservation_confirmation_message'|trans }}</p>
                    </div>

                    {# Reference Code - Prominent Display #}
                    <div class="reference-code-display text-center mb-4 p-4 bg-light rounded">
                        <p class="text-muted mb-2 small">{{ 'reference_code'|trans }}</p>
                        <h2 class="fw-bold text-primary mb-0" style="letter-spacing: 2px; font-family: monospace;">
                            {{ reservation.referenceCode }}
                        </h2>
                        <small class="text-muted">{{ 'please_save_this_code'|trans }}</small>
                    </div>

                    {# Guest Information #}
                    <div class="row mb-2">
                        <div class="col-md-6">
                            <div class="info-item">
                                <i class="bi bi-person-fill text-secondary-custom me-2"></i>
                                <span class="fw-bold">{{ 'guest_name'|trans }}:</span>
                                <p class="mb-0 ms-4">{{ reservation.fullName }}</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-item">
                                <i class="bi bi-envelope-fill text-secondary-custom me-2"></i>
                                <span class="fw-bold">{{ 'email'|trans }}:</span>
                                <p class="mb-0 ms-4">{{ reservation.email }}</p>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-md-6">
                            <div class="info-item">
                                <i class="bi bi-telephone-fill text-secondary-custom me-2"></i>
                                <span class="fw-bold">{{ 'phone'|trans }}:</span>
                                <p class="mb-0 ms-4">{{ reservation.phoneNumber }}</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-item">
                                <i class="bi bi-people-fill text-secondary-custom me-2"></i>
                                <span class="fw-bold">{{ 'party_size'|trans }}:</span>
                                <p class="mb-0 ms-4">{{ reservation.partySize }} {{ 'guests'|trans }}</p>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4">

                    {# Reservation Date & Time #}
                    <div class="row mb-2">
                        <div class="col-md-6">
                            <div class="info-item">
                                <i class="bi bi-calendar3 text-secondary-custom me-2"></i>
                                <span class="fw-bold">{{ 'date'|trans }}:</span>
                                <p class="mb-0 ms-4">{{ reservation.reservationDate|date('l, F j, Y') }}</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-item">
                                <i class="bi bi-clock-fill text-secondary-custom me-2"></i>
                                <span class="fw-bold">{{ 'time'|trans }}:</span>
                                <p class="mb-0 ms-4">{{ reservation.timeSlot|date('g:i A') }}</p>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-md-6">
                            <div class="info-item">
                                <i class="bi bi-tag-fill text-secondary-custom me-2"></i>
                                <span class="fw-bold">{{ 'reservation_type'|trans }}:</span>
                                <p class="mb-0 ms-4">
                                    <span class="badge bg-{{ reservation.isPrivateDining ? 'warning' : 'info' }}">
                                        {{ reservation.reservationTypeLabel }}
                                    </span>
                                </p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-item">
                                <i class="bi bi-info-circle-fill text-secondary-custom me-2"></i>
                                <span class="fw-bold">{{ 'status'|trans }}:</span>
                                <p class="mb-0 ms-4">
                                    <span class="badge bg-{{ reservation.statusBadgeClass }}">
                                        {{ reservation.statusLabel }}
                                    </span>
                                </p>
                            </div>
                        </div>
                    </div>

                    {% if reservation.specialRequests %}
                        <hr class="my-4">
                        <div class="info-item">
                            <i class="bi bi-chat-square-text-fill text-secondary-custom me-2"></i>
                            <span class="fw-bold">{{ 'special_requests'|trans }}:</span>
                            <p class="mb-0 ms-4 mt-2">{{ reservation.specialRequests }}</p>
                        </div>
                    {% endif %}

                    {# Important Information Alert #}
                    <div class="alert alert-info mt-4" role="alert">
                        <h6 class="alert-heading">
                            <i class="bi bi-info-circle-fill me-2"></i>
                            {{ 'important_information'|trans }}
                        </h6>
                        <ul class="mb-0 small">
                            <li>{{ 'confirmation_email_sent'|trans }}</li>
                            <li>{{ 'arrive_15_minutes_early'|trans }}</li>
                            <li>{{ 'contact_for_changes'|trans }}</li>
                            <li>{{ 'reference_code_required'|trans }}</li>
                        </ul>
                    </div>
                </div>
                <div class="modal-footer justify-content-center">
                    <button type="button" class="btn btn-md-lg btn-primary" data-bs-dismiss="modal">
                        <i class="bi bi-check-lg"></i>
                        {{ 'close'|trans }}
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const modalElement = document.getElementById('confirmationModal');

            if (!modalElement) {
                console.error('Modal element not found!');
                return;
            }
            
            if (typeof bootstrap === 'undefined') {
                console.error('Bootstrap is not loaded!');
                return;
            }

            try {
                const confirmationModal = new bootstrap.Modal(modalElement, {
                    backdrop: 'static',
                    keyboard: false
                });
                confirmationModal.show();
            } catch (error) {
                console.error('Error showing modal:', error);
            }
        });
    </script>
{% endif %}
